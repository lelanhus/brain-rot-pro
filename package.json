{
	"name": "brain-rot-pro",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest run --project server",
		"test:convex": "vitest run --project convex",
		"test:component": "vitest run --project client",
		"test:e2e": "playwright test",
		"convex:dev": "convex dev",
		"convex:seed": "convex run seed:seed",
		"verify": "bun run check && bun run lint && bun run test:unit && bun run test:convex && bun run test:component",
		"verify:full": "bun run verify && bun run test:e2e"
	},
	"devDependencies": {
		"@edge-runtime/vm": "^5.0.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^22.19.21",
		"@vitest/browser-playwright": "^4.1.9",
		"convex-test": "^0.0.53",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.61.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@convex-dev/workpool": "^0.4.7",
		"@mmailaender/convex-better-auth-svelte": "^0.8.0",
		"@vercel/analytics": "^2.0.1",
		"ai": "^6.0.208",
		"better-auth": "~1.6.15",
		"convex": "^1.41.0",
		"convex-svelte": "^0.13.0",
		"jpeg-js": "^0.4.4",
		"zod": "^4.4.3"
	}
}
