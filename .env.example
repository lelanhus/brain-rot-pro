# Convex deployment URL (public). Set by `npx convex dev`, which writes it for you.
# Copy this file to .env.local and fill in your deployment URL.
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ─────────────────────────────────────────────────────────────────────────────
# Convex deployment SECRETS — set with `npx convex env set <NAME> "<value>"`
# (or the dashboard), NEVER as PUBLIC_ vars (they must never reach the client
# bundle). Listed here for documentation only; do not put real values in this
# file. The app fails loudly at boot if a required one is missing.
#
#   # AI Gateway key (generation + embeddings). Any ONE of these names works:
#   npx convex env set AI_GATEWAY_API_KEY "<vercel-ai-gateway-key>"
#   # Optional model overrides (defaults are current Gateway slugs):
#   npx convex env set GENERATION_MODEL "anthropic/claude-sonnet-4.5"
#   npx convex env set VALIDATION_MODEL "anthropic/claude-haiku-4.5"
#   npx convex env set EMBEDDING_MODEL  "openai/text-embedding-3-small"
#
#   # SITE_URL — the app's own origin; baseURL for the Better Auth OAuth callback
#   # (`<SITE_URL>/api/auth/callback/google`). Required for Google sign-in.
#   npx convex env set SITE_URL "https://your-app-domain"
#
#   # Google OAuth credentials (required for Google sign-in):
#   npx convex env set GOOGLE_CLIENT_ID     "<...>.apps.googleusercontent.com"
#   npx convex env set GOOGLE_CLIENT_SECRET "<...>"
#
#   # ADMIN_TOKEN gates the /admin/* surface (offers + account/analytics tools):
#   npx convex env set ADMIN_TOKEN "<a long random string>"

# Monetization (ADR-008) — OPTIONAL ad-network slot. Leave unset to use the
# affiliate-offers provider (no approval needed; add offers via api.affiliate.add).
# Once a network approves you, set these and it fills the sponsored slot
# automatically — no code change, no per-ad work:
# PUBLIC_AD_NETWORK=adsense
# PUBLIC_AD_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# PUBLIC_AD_SLOT=1234567890
# PUBLIC_AD_LAYOUT_KEY=-fb+5w+4e-db+86

#   # Per-device rate limits (W5) — OPTIONAL. Defaults are generous; override the
#   # token-bucket refill rate per path (period/capacity fixed in code):
#   npx convex env set RL_ENSURE_SUPPLY_RATE "5"     # per 10 min/device
#   npx convex env set RL_FOR_CARD_RATE      "30"    # per min/device
#   npx convex env set RL_INTERESTS_ADD_RATE "20"    # per min/device
