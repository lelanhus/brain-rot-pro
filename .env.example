# Convex deployment URL (public). Set by `npx convex dev`, which writes it for you.
# Copy this file to .env.local and fill in your deployment URL.
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# The AI Gateway key (for generation + embeddings) and the model overrides
# (GENERATION_MODEL / VALIDATION_MODEL / EMBEDDING_MODEL) are secrets set on the
# Convex deployment (dashboard or `npx convex env set`), NOT here.
